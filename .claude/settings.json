{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Read",
      "Bash(npm run *)",
      "Bash(npx vp *)",
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(rm -f *.lock)",
      "Bash(cat *)",
      "Bash(lsof *)",
      "mcp__chrome-devtools__*",
      "mcp__Claude_Preview__preview_start",
      "mcp__Claude_Preview__preview_stop",
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_eval",
      "mcp__Claude_Preview__preview_logs",
      "mcp__Claude_Preview__preview_snapshot",
      "mcp__Claude_Preview__preview_resize"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CWD=$(echo \"$INPUT\" | jq -r '.cwd'); FILE=$(echo \"$INPUT\" | jq -r '.tool_input.file_path // .tool_input.filePath'); cd \"$CWD\" && npx vp fmt \"$FILE\" 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
